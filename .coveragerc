[run]
branch = True
# Use relative paths so Coveralls can match files to the repo (fixes "0%" / no source file info)
relative_files = True
source = src/vitalDSP
omit =
    tests/*
    migrations/*
    */site-packages/*

[report]
exclude_lines =
    if __name__ == .__main__.:
    pragma: no cover
    raise NotImplementedError